---
import BaseLayout from './BaseLayout.astro';
import TopNav from '../components/nav/TopNav.astro';
import MobileMenu from '../components/nav/MobileMenu.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const homeBase = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} — Schmitz Systemarchitektur`} description={description}>
  <TopNav variant="dark" homeHref={homeBase} />
  <MobileMenu homeHref={homeBase} />

  <main class="legal">
    <div class="container">
      <h1>{title}</h1>
      <slot />
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal {
    background: var(--bg);
    color: var(--ink);
    padding-block: 140px 96px;
    min-height: 60vh;
  }

  .legal h1 {
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.05;
    margin: 0 0 48px;
  }

  .legal :global(h2) {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 48px 0 16px;
  }

  .legal :global(h2:first-of-type) {
    margin-top: 0;
  }

  .legal :global(p) {
    font-size: 17px;
    line-height: 1.6;
    max-width: 720px;
    margin: 0 0 18px;
  }

  .legal :global(ul) {
    font-size: 17px;
    line-height: 1.6;
    max-width: 720px;
    margin: 0 0 18px;
    padding-left: 24px;
  }

  .legal :global(ul li) {
    margin-bottom: 6px;
  }

  .legal :global(a) {
    color: var(--ink);
    border-bottom: 1px solid currentColor;
    text-decoration: none;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .legal :global(a:hover),
  .legal :global(a:focus-visible) {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 720px) {
    .legal {
      padding-block: 96px 64px;
    }
    .legal h1 {
      font-size: 32px;
    }
  }
</style>
