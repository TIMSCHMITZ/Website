---
import MonoMarker from '../brand/MonoMarker.astro';
import Accent from '../brand/Accent.astro';
import { werdegang } from '../../data/werdegang';
---

<section id="vita" class="section werdegang">
  <div class="container">
    <MonoMarker>09 · Werdegang</MonoMarker>

    <div class="werdegang__grid">
      <h2 class="werdegang__h2">
        Vom Hörsaal in den Betrieb. <Accent>Gelernt am Tisch des Kunden.</Accent>
      </h2>

      <div class="werdegang__list">
        {werdegang.map((e) => (
          <div class="werdegang__row">
            <div class="werdegang__when">{e.when}</div>
            <div>
              <div class="werdegang__what">{e.what}</div>
              <p class="werdegang__body">{e.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .werdegang__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 96px;
    margin-top: 24px;
  }

  .werdegang__h2 {
    font-size: 42px;
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.05;
    margin: 0;
  }

  .werdegang__list {
    display: grid;
    row-gap: 24px;
  }

  .werdegang__row {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 24px;
    padding-top: 18px;
    border-top: 1px solid rgba(22, 34, 58, 0.18);
  }

  .werdegang__when {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--steel);
    padding-top: 3px;
  }

  .werdegang__what {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.012em;
  }

  .werdegang__body {
    font-size: 15px;
    line-height: 1.55;
    margin: 6px 0 0;
    opacity: 0.78;
  }

  @media (max-width: 900px) {
    .werdegang__grid {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-top: 16px;
    }
    .werdegang__h2 { font-size: 28px; }
    .werdegang__row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
