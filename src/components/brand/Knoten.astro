---
interface Props {
  size?: number;
  variant?: 'dark' | 'light';
  class?: string;
}

const { size = 120, variant = 'dark', class: className } = Astro.props;
const bar = variant === 'light' ? '#f1ebde' : '#16223a';
---

<svg
  class={className}
  viewBox="147.29 147.29 605.42 605.42"
  width={size}
  height={size}
  aria-hidden="true"
  focusable="false"
>
  <g fill={bar}>
    <rect x="147.29" y="635.53" width="404.04" height="93.56" />
    <rect
      x="409.17"
      y="463.01"
      width="404.04"
      height="93.56"
      transform="translate(475.3 1293.99) rotate(-120)"
    />
    <rect
      x="128.82"
      y="322.47"
      width="404.04"
      height="93.56"
      transform="translate(816.04 267.36) rotate(120)"
    />
  </g>
  <circle cx="428.76" cy="520.66" r="53.04" fill="#b85a3f" />
</svg>
