---
import Plakette from '../brand/Plakette.astro';
import Knoten from '../brand/Knoten.astro';
import { navItems, contact } from '../../data/nav';

interface Props {
  homeHref?: string;
}

const { homeHref = '#' } = Astro.props;
---

<div id="mobile-menu" class="menu" aria-hidden="true" role="dialog" aria-label="Navigation" aria-modal="true">
  <nav class="menu__nav" aria-label="Hauptnavigation mobil">
    {navItems.map((item) => (
      <a class="menu__link" href={item.href} data-menu-link>{item.label}</a>
    ))}
    <a class="menu__link menu__link--cta" href="#kontakt" data-menu-link>Knoten lösen →</a>
  </nav>

  <div class="menu__footer">
    <a class="menu__brand" href={homeHref} data-menu-link aria-label="Start">
      <Plakette size="sm" variant="light" />
    </a>
    <Knoten size={64} variant="light" strokeWidth={6} />
  </div>

  <div class="menu__contact">
    <a href={`tel:${contact.phone.replace(/\s+/g, '')}`} data-menu-link>{contact.phone}</a>
    <span aria-hidden="true">·</span>
    <a href={`mailto:${contact.email}`} data-menu-link>E-Mail</a>
  </div>
</div>

<style>
  .menu {
    position: fixed;
    inset: 0;
    background: var(--ink);
    color: var(--bg);
    z-index: 50;
    padding: calc(var(--nav-height) + 32px) var(--pad-x-mobile) 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  :global(body[data-menu-open='true']) .menu {
    opacity: 1;
    pointer-events: auto;
  }

  .menu__nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 32px;
  }

  .menu__link {
    color: var(--bg);
    text-decoration: none;
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.1;
    transition: color 120ms ease;
  }

  .menu__link:hover,
  .menu__link:focus-visible {
    color: var(--accent);
  }

  .menu__link--cta {
    margin-top: 8px;
    font-size: 18px;
    font-family: var(--mono);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .menu__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid rgba(241, 235, 222, 0.18);
  }

  .menu__brand {
    color: inherit;
    text-decoration: none;
  }

  .menu__contact {
    display: flex;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 16px;
    opacity: 0.7;
  }

  .menu__contact a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  @media (min-width: 901px) {
    .menu { display: none; }
  }
</style>

<script>
  const body = document.body;
  const btn = document.getElementById('menu-toggle');
  const overlay = document.getElementById('mobile-menu');

  function setOpen(open: boolean) {
    body.dataset.menuOpen = String(open);
    btn?.setAttribute('aria-expanded', String(open));
    btn?.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    overlay?.setAttribute('aria-hidden', String(!open));
  }

  btn?.addEventListener('click', () => {
    setOpen(body.dataset.menuOpen !== 'true');
  });

  overlay?.querySelectorAll('[data-menu-link]').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && body.dataset.menuOpen === 'true') {
      setOpen(false);
      btn?.focus();
    }
  });
</script>
