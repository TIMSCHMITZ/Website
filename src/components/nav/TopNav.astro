---
import LogoLockup from '../brand/LogoLockup.astro';
import CTA from '../brand/CTA.astro';
import { navItems } from '../../data/nav';

interface Props {
  variant?: 'dark' | 'light';
  homeHref?: string;
}

const { variant = 'light', homeHref = '#' } = Astro.props;
---

<nav class={`topnav topnav--${variant}`} aria-label="Hauptnavigation">
  <a href={homeHref} class="topnav__brand" aria-label="Schmitz Systemarchitektur — Start">
    <LogoLockup variant={variant} />
  </a>

  <div class="topnav__desktop">
    {navItems.map((item) => (
      <a class="topnav__link" href={item.href}>{item.label}</a>
    ))}
    <CTA href="#kontakt" variant={variant}>Knoten lösen</CTA>
  </div>

  <button
    id="menu-toggle"
    class="topnav__burger"
    type="button"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label="Menü öffnen"
  >
    <span></span>
    <span></span>
  </button>
</nav>

<style>
  .topnav {
    max-width: var(--container);
    margin: 0 auto;
    padding: 32px var(--pad-x) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    position: relative;
    z-index: 2;
  }

  .topnav--dark { color: var(--ink); }
  .topnav--light { color: var(--bg); }

  .topnav__brand {
    color: inherit;
    text-decoration: none;
  }

  .topnav__desktop {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .topnav__link {
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    opacity: 0.82;
    transition: opacity 120ms ease, color 120ms ease;
  }

  .topnav__link:hover,
  .topnav__link:focus-visible {
    opacity: 1;
    color: var(--accent);
  }

  .topnav__burger {
    display: none;
    background: transparent;
    border: 0;
    padding: 8px;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
  }

  .topnav__burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: currentColor;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  :global(body[data-menu-open='true']) .topnav__burger span:nth-child(1) {
    transform: translateY(3.75px) rotate(45deg);
  }

  :global(body[data-menu-open='true']) .topnav__burger span:nth-child(2) {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  @media (max-width: 900px) {
    .topnav {
      padding-inline: var(--pad-x-mobile);
    }
    .topnav__desktop { display: none; }
    .topnav__burger { display: flex; }
  }
</style>
